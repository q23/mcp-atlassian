# =============================================================================
# MCP Atlassian — Dokploy Deployment (Multi-User OAuth Proxy)
# =============================================================================
# Kopiere diese Datei nach `.env` (direkt neben docker-compose.yml) und fülle
# alle REQUIRED-Werte. In Dokploy kannst du diese Variablen auch im Service-UI
# unter "Environment" setzen — dann brauchst du keine .env-Datei im Repo.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Atlassian-Instanz (genau EINE Cloud-Instanz — alle Kollegen sind dort Mitglied)
# -----------------------------------------------------------------------------
JIRA_URL=https://your-company.atlassian.net
CONFLUENCE_URL=https://your-company.atlassian.net/wiki

# -----------------------------------------------------------------------------
# OAuth 2.0 (3LO) — Firmen-App in Atlassian Developer Console
# https://developer.atlassian.com/console/myapps/
# -----------------------------------------------------------------------------
# Anleitung siehe dokploy/README.md (Schritt "OAuth-App anlegen").
ATLASSIAN_OAUTH_CLIENT_ID=replace_me
ATLASSIAN_OAUTH_CLIENT_SECRET=replace_me

# Muss EXAKT mit der in der Atlassian-App hinterlegten Redirect-URI übereinstimmen.
# Beispiel: https://mcp.firma.de/callback
ATLASSIAN_OAUTH_REDIRECT_URI=https://mcp.firma.de/callback

# Scopes — `offline_access` ist PFLICHT (Refresh-Tokens).
ATLASSIAN_OAUTH_SCOPE=read:jira-work write:jira-work read:jira-user read:confluence-space.summary read:confluence-content.summary read:confluence-content.all write:confluence-content search:confluence read:page:confluence offline_access

# Cloud-ID der Atlassian-Instanz — einmalig per `--oauth-setup` Wizard ermitteln
# und hier fest eintragen.
ATLASSIAN_OAUTH_CLOUD_ID=replace_me

# -----------------------------------------------------------------------------
# MCP OAuth Proxy — aktiviert /.well-known + DCR für MCP-Clients (Claude, ChatGPT, …)
# -----------------------------------------------------------------------------
ATLASSIAN_OAUTH_PROXY_ENABLE=true

# Öffentliche Basis-URL unter der dieser Service von MCP-Clients erreichbar ist.
# WICHTIG: ohne trailing slash, HTTPS.
PUBLIC_BASE_URL=https://mcp.firma.de

# Erlaubte Client-Redirect-URIs (Wildcards für localhost-Clients; ChatGPT-Connector).
ATLASSIAN_OAUTH_ALLOWED_CLIENT_REDIRECT_URIS=http://localhost:*,http://127.0.0.1:*,https://chatgpt.com/connector_platform_oauth_redirect

# Erzwingbare DCR-Grant-Types.
ATLASSIAN_OAUTH_ALLOWED_GRANT_TYPES=authorization_code,refresh_token

# Nutzer müssen beim ersten Login die Berechtigungen bestätigen.
ATLASSIAN_OAUTH_REQUIRE_CONSENT=true

# -----------------------------------------------------------------------------
# Server-Verhalten
# -----------------------------------------------------------------------------
# Traefik (Dokploy) terminiert TLS → Authorization-Header von Proxy NICHT ignorieren.
# IGNORE_HEADER_AUTH=false  # default

# Read-only-Modus global aktivieren (blockiert alle Schreib-Tools):
# READ_ONLY_MODE=true

# Toolset-Filter — falls nicht gesetzt, sind aktuell alle 68 Tools aktiv.
# Ab v0.22.0 wird Default "default" (core, ~23 Tools). Explizit setzen:
# TOOLSETS=all
# oder z. B.:
# TOOLSETS=default,jira_agile

# Optional: Tools/Projekte/Spaces einschränken
# ENABLED_TOOLS=jira_search,jira_get_issue,confluence_search,confluence_get_page
# JIRA_PROJECTS_FILTER=PROJ,DEVOPS
# CONFLUENCE_SPACES_FILTER=DEV,DOC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Setze ggf. MCP_VERY_VERBOSE=true für Debug-Logs (generiert viel Output).
# MCP_VERBOSE=true
